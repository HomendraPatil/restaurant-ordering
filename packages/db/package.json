{
  "name": "@restaurant/db",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "prisma db seed",
    "studio": "export DATABASE_URL='postgresql://postgres:postgres@localhost:5432/restaurant?schema=public' && prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "dotenv": "^16.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "uuid": "^11.0.0"
  }
}
