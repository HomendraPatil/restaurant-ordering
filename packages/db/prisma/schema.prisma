generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  RECEIVED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  PAYMENT_FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CustomizationType {
  SIZE
  ADDON
  TEXT
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  phone        String?
  role         Role      @default(CUSTOMER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  addresses       Address[]
  cartItems       CartItem[]
  orders          Order[]
  changedStatuses OrderStatusHistory[]

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  sessionToken  String    @unique @map("session_token")
  userId        String?   @map("user_id")
  refreshToken  String?   @map("refresh_token")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Address {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  addressLine String   @map("address_line")
  city        String
  state       String?
  pincode     String
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?   @map("image_url")
  slug        String    @unique
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id              String   @id @default(uuid())
  categoryId      String   @map("category_id")
  slug            String   @unique
  name            String
  description     String?
  imageUrl        String?  @map("image_url")
  price           Decimal  @db.Decimal(10, 2)
  preparationTime Int      @default(15) @map("preparation_time")
  isAvailable     Boolean  @default(true) @map("is_available")
  isVegetarian    Boolean  @default(false) @map("is_vegetarian")
  isVegan         Boolean  @default(false) @map("is_vegan")
  isGlutenFree    Boolean  @default(false) @map("is_gluten_free")
  stockQuantity   Int      @default(100) @map("stock_quantity")
  isLimited       Boolean  @default(false) @map("is_limited")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category       Category                  @relation(fields: [categoryId], references: [id])
  customizations ItemCustomizationGroup[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([categoryId])
  @@index([slug])
  @@map("menu_items")
}

model ItemCustomizationGroup {
  id            String            @id @default(uuid())
  menuItemId    String            @map("menu_item_id")
  type          CustomizationType
  name          String
  isRequired    Boolean           @default(false)
  minSelections Int               @default(0) @map("min_selections")
  maxSelections Int               @default(1) @map("max_selections")
  sortOrder     Int               @default(0) @map("sort_order")

  menuItem MenuItem              @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  CustomizationOption[]

  @@map("item_customization_groups")
}

model CustomizationOption {
  id             String   @id @default(uuid())
  groupId        String   @map("group_id")
  name           String
  priceModifier  Decimal  @default(0) @map("price_modifier") @db.Decimal(10, 2)
  isDefault      Boolean  @default(false) @map("is_default")
  sortOrder      Int      @default(0) @map("sort_order")

  group                  ItemCustomizationGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  cartItemCustomizations CartItemCustomization[]

  @@map("customization_options")
}

model CartItem {
  id                 String   @id @default(uuid())
  sessionId          String?  @map("session_id")
  userId             String?  @map("user_id")
  menuItemId         String   @map("menu_item_id")
  quantity           Int      @default(1)
  unitPrice          Decimal  @map("unit_price") @db.Decimal(10, 2)
  customizationPrice Decimal  @default(0) @map("customization_price") @db.Decimal(10, 2)
  specialInstructions String?  @map("special_instructions")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  menuItem      MenuItem                  @relation(fields: [menuItemId], references: [id])
  user          User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customizations CartItemCustomization[]

  @@index([userId])
  @@index([sessionId])
  @@map("cart_items")
}

model CartItemCustomization {
  id        String @id @default(uuid())
  cartItemId String @map("cart_item_id")
  optionId  String @map("option_id")

  cartItem CartItem             @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  option   CustomizationOption @relation(fields: [optionId], references: [id])

  @@map("cart_item_customizations")
}

model Order {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  status             OrderStatus @default(RECEIVED)
  subtotal           Decimal     @db.Decimal(10, 2)
  taxAmount          Decimal     @map("tax_amount") @db.Decimal(10, 2)
  totalAmount        Decimal     @map("total_amount") @db.Decimal(10, 2)
  addressId          String      @map("address_id")
  razorpayPaymentId  String?     @unique @map("razorpay_payment_id")
  specialInstructions String?    @map("special_instructions")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id])
  address       Address               @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(uuid())
  orderId              String   @map("order_id")
  menuItemId           String   @map("menu_item_id")
  quantity             Int
  unitPrice            Decimal  @map("unit_price") @db.Decimal(10, 2)
  customizationPrice   Decimal  @map("customization_price") @db.Decimal(10, 2)
  specialInstructions  String?  @map("special_instructions")
  selectedOptions      Json?    @map("selected_options")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Payment {
  id               String        @id @default(uuid())
  orderId          String        @unique @map("order_id")
  razorpayPaymentId String?      @unique @map("razorpay_payment_id")
  amount           Decimal       @db.Decimal(10, 2)
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String      @map("order_id")
  oldStatus   OrderStatus? @map("old_status")
  newStatus   OrderStatus
  changedById String?      @map("changed_by_id")
  changedAt   DateTime    @default(now()) @map("changed_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedById], references: [id])

  @@map("order_status_history")
}
