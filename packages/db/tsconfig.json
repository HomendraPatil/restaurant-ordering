{
  "compilerOptions": {
    "module": "commonjs",
    "lib": ["ES2022"],
    "target": "ES2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
