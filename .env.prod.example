# ============================================
# Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.prod.example .env

# PostgreSQL
POSTGRES_PASSWORD=change-this-to-a-strong-password

# MinIO / S3
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
S3_BUCKET=restaurant-images
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# JWT (MUST be changed in production)
JWT_ACCESS_SECRET=change-this-to-a-strong-access-secret
JWT_REFRESH_SECRET=change-this-to-a-strong-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay (Production keys)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# App URLs
CUSTOMER_APP_URL=http://localhost:3001
ADMIN_APP_URL=http://localhost:3002

# Frontend API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3002
